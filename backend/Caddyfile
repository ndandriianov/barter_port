:80 {
	# Логи в консоль контейнера
	log {
		output stdout
		format console
	}

	# Preflight (OPTIONS) — отвечаем сразу на прокси
	@preflight method OPTIONS
	handle @preflight {
		header Access-Control-Allow-Origin "http://localhost:5173"
		header Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
		header Access-Control-Allow-Headers "Accept, Authorization, Content-Type"
		header Access-Control-Allow-Credentials "true"
		header Access-Control-Max-Age "86400"
		respond "" 204
	}

	# Заголовки CORS для обычных запросов (и /auth, и остальных)
	header {
		Access-Control-Allow-Origin "http://localhost:5173"
		Access-Control-Allow-Credentials "true"
		Vary "Origin"
	}

	# swagger
	handle /docs* {
		reverse_proxy swagger-ui:8080
	}

	handle /swagger-specs/auth/swagger.json {
		reverse_proxy auth:8080 {
			rewrite /swagger/doc.json
		}
	}

	handle /swagger-specs/items/* {
		uri replace /swagger-specs/items /swagger
		reverse_proxy items:8080
	}

	handle /swagger-specs/users/* {
		uri replace /swagger-specs/users /swagger
		reverse_proxy users:8080
	}

	handle /swagger-specs/chats/* {
		uri replace /swagger-specs/chats /swagger
		reverse_proxy chats:8080
	}

	# SeaweedFS S3 — публичный доступ к файлам (аватарам) с клиента
	handle /s3/* {
		uri strip_prefix /s3
		reverse_proxy seaweedfs:8333
	}

	# Auth service по префиксу /auth/*
	handle /auth/* {
		reverse_proxy auth:8080 # локально host.docker.internal:8081
	}

	handle /users/admin/* {
		uri replace /users/admin /admin
		reverse_proxy users:8080
	}

	handle /chats/admin/* {
		uri replace /chats/admin /admin
		reverse_proxy chats:8083
	}

	handle /deals/admin/* {
		uri replace /deals/admin /admin
		reverse_proxy items:8080
	}

	# Users service по префиксу /users/*
	handle /users/* {
		reverse_proxy users:8080
	}

	# Chats service по префиксу /chats*
	handle /chats* {
		reverse_proxy chats:8083
	}

	# Всё остальное — основной backend
	handle {
		reverse_proxy items:8080 # локально host.docker.internal:8080
	}
}
